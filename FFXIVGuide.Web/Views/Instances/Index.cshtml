@model PagedValue<FFXIVGuide.Web.Data.Instance.InstanceModel>

@{
    ViewData["Title"] = "Instances";
}

<div class="row justify-content-between border-bottom mb-3">
    <h1 class="col">@ViewData["Title"]</h1>
    <div class="col-auto">
        <button class="btn btn-success"
                hx-get="/Instances/Create" hx-target="#new-instance-modal"
                data-bs-toggle="modal" data-bs-target="#new-instance-modal">
            Add Instance
        </button>
    </div>
</div>

<div id="data-list">
    <partial name="DataList" for="@Model"/>
</div>

<div id="new-instance-modal" class="modal modal-blur fade" style="display: none" aria-hidden="false" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content"></div>
    </div>
</div>

@section Scripts{
    <script>
        document.getElementById('new-instance-modal').addEventListener('shown.bs.modal', () => {
            document.getElementById('Name').focus()
        });
    </script>
    <partial name="_ValidationScriptsPartial" />
}