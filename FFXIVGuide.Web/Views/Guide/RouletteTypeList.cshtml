@model Dictionary<int, string>

<label class="form-label">Roulette Type</label>
<select class="form-select mb-2" name="RouletteTypeId" hx-get="/Guide/InstanceList" hx-target="#instanceList">
    <option value=""></option>
    @foreach(var kvp in Model)
    {
        <option value="@kvp.Key">@kvp.Value</option>
    }
</select>