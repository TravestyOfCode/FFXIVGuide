@model FFXIVGuide.Web.Data.Instance.InstanceModel

@if (Model != null)
{
    <div class="card border-0 shadow-none mb-3">
        <img src="@Model.ImageUrl" class="card-img" />
        <div class="card-img-overlay d-flex">
            <h1 class="card-title fw-bolder align-self-center">@Model.Name</h1>
        </div>
    </div>

    @if (User?.Identity?.Name != null)
    {
        <div class="row justify-content-end mb-3">
            <button class="btn btn-success col-auto" hx-post="/Guide/Create/@Model.Id" hx-target="#instanceDetails" hx-prompt="Encounter Name">Add Encounter</button>
        </div>
    }
    <div id="encounters">
        @foreach (var encounter in Model.Encounters)
        {
            <partial name="Encounter" for="@encounter" />
        }
    </div>
}
else
{
    <h2 class="text-center">Please search for an Instance using the controls to the side.</h2>
}